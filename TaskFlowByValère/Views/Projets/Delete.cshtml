@model TaskFlowByValere.Models.Projet

@{
    ViewData["Title"] = "Supprimer le projet";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #dc3545;">🗑️ Supprimer le projet</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Retour</a>
    </div>

    <div class="card shadow-sm border-0 border-danger" style="max-width: 600px;">
        <div class="card-header text-white fw-bold" style="background-color: #dc3545;">
            ⚠️ Confirmer la suppression
        </div>
        <div class="card-body">

            <div class="alert alert-danger">
                ⚠️ Cette action est <strong>irréversible</strong>.
                Tous les tickets liés à ce projet seront également supprimés.
            </div>

            <p><strong>Nom :</strong> @Model.Nom</p>
            <p><strong>Description :</strong> @(Model.Description ?? "Aucune description")</p>
            <p><strong>Statut :</strong> @Model.Statut</p>
            <p><strong>Date de création :</strong> @Model.DateCreation.ToString("dd/MM/yyyy")</p>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-danger">
                        🗑️ Oui, supprimer
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>

</div>