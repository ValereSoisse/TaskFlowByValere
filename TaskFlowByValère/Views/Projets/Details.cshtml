@model TaskFlowByValere.Models.Projet

@{
    ViewData["Title"] = "Détails du projet";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #0A1F44;">📁 @Model.Nom</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Retour</a>
    </div>

    <!-- Infos projet -->
    <div class="card mb-4 shadow-sm border-0">
        <div class="card-header text-white fw-bold" style="background-color: #0A1F44;">
            📋 Informations
        </div>
        <div class="card-body">
            <p><strong>Description :</strong> @(Model.Description ?? "Aucune description")</p>
            <p><strong>Date de création :</strong> @Model.DateCreation.ToString("dd/MM/yyyy")</p>
            <p>
                <strong>Statut :</strong>
                <span class="badge" style="background-color:
                    @(Model.Statut == "En cours" ? "#1A6FD4" :
                                                          Model.Statut == "Terminé" ? "#198754" : "#6c757d")">
                    @Model.Statut
                </span>
            </p>
        </div>
        <div class="card-footer bg-white border-0">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">✏️ Modifier</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm ms-2">🗑️ Supprimer</a>
        </div>
    </div>

    <!-- Tickets du projet -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 style="color: #0A1F44;">🎫 Tickets (@Model.Tickets.Count)</h4>
        <a asp-controller="Tickets" asp-action="Create" class="btn btn-sm text-white"
           style="background-color: #1A6FD4;">➕ Nouveau ticket</a>
    </div>

    @if (!Model.Tickets.Any())
    {
        <div class="alert text-white text-center" style="background-color: #0A1F44;">
            Aucun ticket pour ce projet.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var ticket in Model.Tickets)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm border-0">
                        <div class="card-header text-white fw-bold d-flex justify-content-between"
                             style="background-color:
                                        @(ticket.Priorite == "Haute" ? "#dc3545" :
                                                               ticket.Priorite == "Normale" ? "#1A6FD4" : "#6c757d")">
                            <span>🎫 @ticket.Titre</span>
                            <span class="badge bg-light text-dark">@ticket.Priorite</span>
                        </div>
                        <div class="card-body">
                            <p class="text-muted small">@(ticket.Description ?? "Aucune description")</p>
                            <span class="badge" style="background-color:
                                        @(ticket.Statut == "En cours" ? "#1A6FD4" :
                                                                                  ticket.Statut == "Terminé" ? "#198754" :
                                                                                  ticket.Statut == "À faire" ? "#ffc107" : "#6c757d");
                                          color: @(ticket.Statut == "À faire" ? "black" : "white")">
                                @ticket.Statut
                            </span>
                        </div>
                        <div class="card-footer bg-white border-0 d-flex gap-2">
                            <a asp-controller="Tickets" asp-action="Edit" asp-route-id="@ticket.Id"
                               class="btn btn-sm btn-outline-warning">✏️</a>
                            <a asp-controller="Tickets" asp-action="Delete" asp-route-id="@ticket.Id"
                               class="btn btn-sm btn-outline-danger">🗑️</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>