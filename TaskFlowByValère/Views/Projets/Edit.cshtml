@model TaskFlowByValere.Models.Projet

@{
    ViewData["Title"] = "Modifier le projet";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #0A1F44;">✏️ Modifier le projet</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Retour</a>
    </div>

    <div class="card shadow-sm border-0" style="max-width: 600px;">
        <div class="card-header text-white fw-bold" style="background-color: #0A1F44;">
            📁 @Model.Nom
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="DateCreation" />

                <div class="mb-3">
                    <label asp-for="Nom" class="form-label fw-bold"></label>
                    <input asp-for="Nom" class="form-control" />
                    <span asp-validation-for="Nom" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Statut" class="form-label fw-bold"></label>
                    <select asp-for="Statut" class="form-select">
                        <option value="En cours">🔵 En cours</option>
                        <option value="Terminé">🟢 Terminé</option>
                        <option value="En pause">⚪ En pause</option>
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn text-white" style="background-color: #f0ad4e;">
                        💾 Sauvegarder
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}