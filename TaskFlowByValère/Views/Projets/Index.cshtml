@model IEnumerable<TaskFlowForValere.Models.Projet>

@{
    ViewData["Title"] = "Projets";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #0A1F44;">📁 Mes Projets</h2>
        <a asp-action="Create" class="btn text-white" style="background-color: #1A6FD4;">
            ➕ Nouveau projet
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert text-white text-center p-5" style="background-color: #0A1F44;">
            <h4>Aucun projet pour le moment</h4>
            <p>Cliquez sur "Nouveau projet" pour commencer !</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var projet in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header text-white fw-bold" style="background-color: #0A1F44;">
                            📁 @projet.Nom
                        </div>
                        <div class="card-body">
                            <p class="card-text text-muted">@(projet.Description ?? "Aucune description")</p>
                            <p class="card-text">
                                <small>📅 @projet.DateCreation.ToString("dd/MM/yyyy")</small>
                            </p>
                            <span class="badge" style="background-color:
                                        @(projet.Statut == "En cours" ? "#1A6FD4" :
                                                                                  projet.Statut == "Terminé" ? "#198754" : "#6c757d")">
                                @projet.Statut
                            </span>
                        </div>
                        <div class="card-footer bg-white border-0 d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@projet.Id"
                               class="btn btn-sm btn-outline-primary">👁️ Détails</a>
                            <a asp-action="Edit" asp-route-id="@projet.Id"
                               class="btn btn-sm btn-outline-warning">✏️ Modifier</a>
                            <a asp-action="Delete" asp-route-id="@projet.Id"
                               class="btn btn-sm btn-outline-danger">🗑️ Supprimer</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>