@model TaskFlowByValere.Models.Ticket

@{
    ViewData["Title"] = "Supprimer le ticket";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #dc3545;">🗑️ Supprimer le ticket</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Retour</a>
    </div>

    <div class="card shadow-sm border-0" style="max-width: 600px;">
        <div class="card-header text-white fw-bold" style="background-color: #dc3545;">
            ⚠️ Confirmer la suppression
        </div>
        <div class="card-body">

            <div class="alert alert-danger">
                ⚠️ Cette action est <strong>irréversible</strong>.
            </div>

            <p><strong>Titre :</strong> @Model.Titre</p>
            <p><strong>Description :</strong> @(Model.Description ?? "Aucune description")</p>
            <p>
                <strong>Priorité :</strong>
                <span class="badge" style="background-color:
                    @(Model.Priorite == "Haute" ? "#dc3545" :
                                                          Model.Priorite == "Normale" ? "#1A6FD4" : "#6c757d")">
                    @Model.Priorite
                </span>
            </p>
            <p>
                <strong>Statut :</strong>
                <span class="badge" style="background-color:
                    @(Model.Statut == "En cours" ? "#1A6FD4" :
                                                          Model.Statut == "Terminé" ? "#198754" :
                                                          Model.Statut == "À faire" ? "#ffc107" : "#6c757d");
                      color: @(Model.Statut == "À faire" ? "black" : "white")">
                    @Model.Statut
                </span>
            </p>
            <p><strong>Assigné à :</strong> @(Model.AssigneA ?? "Non assigné")</p>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-danger">
                        🗑️ Oui, supprimer
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>

</div>