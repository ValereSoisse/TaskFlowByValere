@model TaskFlowByValere.Models.Ticket

@{
    ViewData["Title"] = "Modifier le ticket";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #0A1F44;">✏️ Modifier le ticket</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Retour</a>
    </div>

    <div class="card shadow-sm border-0" style="max-width: 600px;">
        <div class="card-header text-white fw-bold" style="background-color: #1A6FD4;">
            🎫 @Model.Titre
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="DateCreation" />

                <div class="mb-3">
                    <label asp-for="Titre" class="form-label fw-bold"></label>
                    <input asp-for="Titre" class="form-control" />
                    <span asp-validation-for="Titre" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Priorite" class="form-label fw-bold"></label>
                    <select asp-for="Priorite" class="form-select">
                        <option value="Basse">⚪ Basse</option>
                        <option value="Normale">🔵 Normale</option>
                        <option value="Haute">🔴 Haute</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Statut" class="form-label fw-bold"></label>
                    <select asp-for="Statut" class="form-select">
                        <option value="À faire">🟡 À faire</option>
                        <option value="En cours">🔵 En cours</option>
                        <option value="Terminé">🟢 Terminé</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="AssigneA" class="form-label fw-bold"></label>
                    <input asp-for="AssigneA" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="ProjetId" class="form-label fw-bold">Projet</label>
                    <select asp-for="ProjetId" class="form-select"
                            asp-items="ViewBag.ProjetId">
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn text-white" style="background-color: #f0ad4e;">
                        💾 Sauvegarder
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}